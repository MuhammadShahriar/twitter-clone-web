# Base URL of the Twitter clone API (no trailing slash).
# Used by src/lib/api.ts. Must be prefixed with NEXT_PUBLIC_ to be
# readable in the browser.
#
# Use the API's HTTP dev URL in local development so the refresh-token cookie
# (SameSite=Lax; Secure=false in dev) flows from http://localhost:3000 without
# HTTPS/Secure-cookie issues. The web app must run on http://localhost:3000
# (the API's CORS allowlist) for credentialed requests to be accepted.
NEXT_PUBLIC_API_URL=http://localhost:5220
